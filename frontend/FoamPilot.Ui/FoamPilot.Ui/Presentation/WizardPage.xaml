<Page x:Class="FoamPilot.Ui.Presentation.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FoamPilot.Ui.Presentation"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:uer="using:Uno.Extensions.Reactive.UI"
    Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="24" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- Title -->
      <RowDefinition Height="Auto" />  <!-- Stepper bar -->
      <RowDefinition Height="Auto" />  <!-- Status message -->
      <RowDefinition Height="*" />     <!-- Content area -->
      <RowDefinition Height="Auto" />  <!-- Navigation buttons -->
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock Text="Simulation Wizard"
        Style="{ThemeResource TitleLargeTextBlockStyle}" />

    <!-- Stepper Bar -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
      <local:WizardStepIndicator x:Name="Step1" StepNumber="1" StepTitle="Mesh" />
      <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.4" FontSize="20" Margin="4,0" />
      <local:WizardStepIndicator x:Name="Step2" StepNumber="2" StepTitle="Boundaries" />
      <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.4" FontSize="20" Margin="4,0" />
      <local:WizardStepIndicator x:Name="Step3" StepNumber="3" StepTitle="Solver" />
      <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.4" FontSize="20" Margin="4,0" />
      <local:WizardStepIndicator x:Name="Step4" StepNumber="4" StepTitle="Run" />
      <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.4" FontSize="20" Margin="4,0" />
      <local:WizardStepIndicator x:Name="Step5" StepNumber="5" StepTitle="Results" />
    </StackPanel>

    <!-- Status Message -->
    <uer:FeedView Source="{Binding StatusMessage}" Grid.Row="2">
      <uer:FeedView.ValueTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding}"
              Style="{ThemeResource BodyLargeTextBlockStyle}"
              Opacity="0.8" />
        </DataTemplate>
      </uer:FeedView.ValueTemplate>
    </uer:FeedView>

    <!-- Content Area: Template Picker (Step 0) -->
    <Grid Grid.Row="3" x:Name="TemplatePicker">
      <uer:FeedView Source="{Binding Templates}">
        <uer:FeedView.ValueTemplate>
          <DataTemplate>
            <GridView ItemsSource="{Binding}"
                SelectionMode="Single"
                SelectionChanged="TemplateGrid_SelectionChanged">
              <GridView.ItemTemplate>
                <DataTemplate>
                  <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="16"
                      Width="300"
                      Margin="0,0,12,12">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Name}"
                          Style="{ThemeResource SubtitleTextBlockStyle}" />
                      <TextBlock Text="{Binding Description}"
                          Style="{ThemeResource BodyMediumTextBlockStyle}"
                          Opacity="0.7"
                          TextWrapping="Wrap"
                          MaxLines="3" />
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#3F2CAD" CornerRadius="4" Padding="8,2">
                          <TextBlock Text="{Binding Difficulty}"
                              FontSize="12" Foreground="White" />
                        </Border>
                        <TextBlock Text="{Binding Solver}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6"
                            VerticalAlignment="Center" />
                        <TextBlock Text="{Binding EstimatedRuntime}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6"
                            VerticalAlignment="Center" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </GridView.ItemTemplate>
            </GridView>
          </DataTemplate>
        </uer:FeedView.ValueTemplate>
        <uer:FeedView.ProgressTemplate>
          <DataTemplate>
            <ProgressRing IsActive="True" Width="24" Height="24" />
          </DataTemplate>
        </uer:FeedView.ProgressTemplate>
      </uer:FeedView>
    </Grid>

    <!-- Content Area: File Editor (Steps 1-3) -->
    <Grid Grid.Row="3" x:Name="FileEditorPanel" Visibility="Collapsed"
        ColumnSpacing="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="300" />
      </Grid.ColumnDefinitions>

      <!-- File editor -->
      <Grid RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <uer:FeedView Source="{Binding CurrentFilePath}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.6"
                    VerticalAlignment="Center" />
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
          </uer:FeedView>
          <Button Content="Save" Click="SaveFile_Click" Padding="8,4" />
          <Button Content="Revert" Click="RevertFile_Click" Padding="8,4" />
        </StackPanel>

        <TextBox Grid.Row="1"
            x:Name="WizardEditor"
            AcceptsReturn="True"
            TextWrapping="NoWrap"
            FontFamily="Cascadia Code, Consolas, Courier New, monospace"
            FontSize="13"
            TextChanged="Editor_TextChanged"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Auto" />
      </Grid>

      <!-- Validation panel -->
      <Border Grid.Column="1"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8"
          Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Validation"
              Style="{ThemeResource SubtitleTextBlockStyle}" />
          <uer:FeedView Source="{Binding ValidationResults}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <ItemsRepeater ItemsSource="{Binding}">
                  <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                        <TextBlock Text="✓" Foreground="LimeGreen" FontSize="14"
                            Visibility="{Binding Passed}" />
                        <TextBlock Text="✗" Foreground="Tomato" FontSize="14"
                            Visibility="{Binding Passed, Converter={StaticResource InvertBool}}" />
                        <TextBlock Text="{Binding Rule}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
          </uer:FeedView>
          <Button Content="Run Validation" Click="Validate_Click"
              HorizontalAlignment="Stretch"
              Margin="0,8,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Content Area: Run Step (Step 4) -->
    <Grid Grid.Row="3" x:Name="RunPanel" Visibility="Collapsed" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="2*" />
        <RowDefinition Height="3*" />
      </Grid.RowDefinitions>

      <!-- Residual chart placeholder -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8"
          Padding="16">
        <TextBlock Text="Residual chart will appear here during simulation"
            Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- Log output -->
      <ScrollViewer Grid.Row="1" x:Name="WizardLogScroll">
        <uer:FeedView Source="{Binding LogLines}">
          <uer:FeedView.ValueTemplate>
            <DataTemplate>
              <ItemsRepeater ItemsSource="{Binding}">
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Text}"
                        FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                        FontSize="12"
                        TextWrapping="NoWrap"
                        IsTextSelectionEnabled="True" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </DataTemplate>
          </uer:FeedView.ValueTemplate>
        </uer:FeedView>
      </ScrollViewer>
    </Grid>

    <!-- Content Area: Results (Step 5) -->
    <Grid Grid.Row="3" x:Name="ResultsPanel" Visibility="Collapsed">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <TextBlock Text="Simulation Complete"
            Style="{ThemeResource TitleLargeTextBlockStyle}"
            HorizontalAlignment="Center" />
        <TextBlock Text="Open in ParaView to visualize the results."
            Style="{ThemeResource BodyLargeTextBlockStyle}"
            Opacity="0.7"
            HorizontalAlignment="Center" />
        <Button Content="Open in ParaView"
            Click="OpenParaView_Click"
            HorizontalAlignment="Center"
            Style="{ThemeResource AccentButtonStyle}"
            Padding="16,8" />
      </StackPanel>
    </Grid>

    <!-- Navigation Buttons -->
    <Grid Grid.Row="4" ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button x:Name="BackButton" Content="Back" Click="Back_Click"
          Padding="16,8" Visibility="Collapsed" />

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
        <uer:FeedView Source="{Binding IsLoading}">
          <uer:FeedView.ValueTemplate>
            <DataTemplate>
              <ProgressRing IsActive="{Binding}" Width="20" Height="20"
                  Visibility="{Binding}" />
            </DataTemplate>
          </uer:FeedView.ValueTemplate>
        </uer:FeedView>
        <Button x:Name="NextButton" Content="Start Wizard" Click="Next_Click"
            Style="{ThemeResource AccentButtonStyle}"
            Padding="16,8" />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
