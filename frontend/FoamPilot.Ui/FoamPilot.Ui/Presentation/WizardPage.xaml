<Page x:Class="FoamPilot.Ui.Presentation.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FoamPilot.Ui.Presentation"
    Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="24,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Step indicator bar -->
    <StackPanel x:Name="StepperBar" Orientation="Horizontal"
        HorizontalAlignment="Center" Spacing="4"
        Margin="0,0,0,16" />

    <!-- Step content area -->
    <ContentControl x:Name="StepContent" Grid.Row="1"
        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />

    <!-- Bottom bar: status + navigation buttons -->
    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <ProgressRing x:Name="BusyIndicator" IsActive="False"
            Width="20" Height="20" Visibility="Collapsed" />
        <TextBlock x:Name="StatusText" VerticalAlignment="Center"
            TextWrapping="Wrap" MaxWidth="600" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button x:Name="BtnBack" Content="← Back" Click="Back_Click"
            IsEnabled="False" />
        <Button x:Name="BtnExecute" Content="Generate Mesh"
            Click="Execute_Click" Visibility="Collapsed"
            Style="{StaticResource AccentButtonStyle}" />
        <Button x:Name="BtnNext" Content="Next →" Click="Next_Click"
            Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
