<Page x:Class="FoamPilot.Ui.Presentation.RunControlPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="24" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Run Control"
        Style="{ThemeResource TitleLargeTextBlockStyle}" />

    <!-- Case selection -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
      <ComboBox x:Name="CaseCombo" Header="Select Case" Width="250" />
      <TextBlock x:Name="SolverText" VerticalAlignment="Bottom"
          Style="{ThemeResource BodyMediumTextBlockStyle}" Opacity="0.7"
          Margin="0,0,0,6" />
    </StackPanel>

    <!-- Command buttons -->
    <StackPanel Grid.Row="2" Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="blockMesh" Click="RunCmd_Click" Tag="blockMesh" Padding="12,8" />
        <Button Content="checkMesh" Click="RunCmd_Click" Tag="checkMesh" Padding="12,8" />
        <Button Content="snappyHexMesh" Click="RunCmd_Click" Tag="snappyHexMesh" Padding="12,8" />
        <Button Content="decomposePar" Click="RunCmd_Click" Tag="decomposePar" Padding="12,8" />
        <Button Content="Run Solver" Click="RunSolver_Click" Padding="12,8" />
        <Button Content="reconstructPar" Click="RunCmd_Click" Tag="reconstructPar" Padding="12,8" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="CustomCmdBox" PlaceholderText="Custom command..." Width="300" />
        <Button Content="Run Custom" Click="RunCustom_Click" Padding="12,8" />
      </StackPanel>
      <TextBlock x:Name="StatusText" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
    </StackPanel>

    <!-- Jobs list -->
    <Grid Grid.Row="3" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="Jobs" Style="{ThemeResource SubtitleTextBlockStyle}" />
        <Button Content="Refresh" Click="RefreshJobs_Click" Padding="8,4" />
      </StackPanel>

      <ListView x:Name="JobsList" Grid.Row="1" SelectionMode="None">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8,4" ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="{Binding JobId}" FontSize="11"
                  FontFamily="Cascadia Code, Consolas, monospace"
                  VerticalAlignment="Center" Opacity="0.5" />
              <TextBlock Text="{Binding Command}" Grid.Column="1"
                  FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                  VerticalAlignment="Center" />
              <TextBlock Text="{Binding Status}" Grid.Column="2"
                  VerticalAlignment="Center" />
              <TextBlock Text="{Binding Elapsed}" Grid.Column="3"
                  VerticalAlignment="Center"
                  Style="{ThemeResource CaptionTextBlockStyle}" />
              <Button Content="Cancel" Grid.Column="4"
                  Tag="{Binding JobId}" Click="CancelJob_Click"
                  Padding="8,2" Visibility="{Binding CanCancel}" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>
  </Grid>
</Page>
