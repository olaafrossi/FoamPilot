<Page x:Class="FoamPilot.Ui.Presentation.RunControlPage"
    x:Name="RunControlRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uer="using:Uno.Extensions.Reactive.UI"
    xmlns:local="using:FoamPilot.Ui.Presentation"
    Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <local:JobStatusToBrushConverter x:Key="StatusBrush" />
  </Page.Resources>

  <Grid Padding="24" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Row 0: Header + Case selector -->
    <Grid ColumnSpacing="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="300" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <TextBlock Text="Run Control"
          Style="{ThemeResource TitleLargeTextBlockStyle}"
          VerticalAlignment="Center" />

      <uer:FeedView Source="{Binding Cases}" Grid.Column="1">
        <uer:FeedView.ValueTemplate>
          <DataTemplate>
            <ComboBox x:Name="CaseComboBox"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding}"
                DisplayMemberPath="Name"
                PlaceholderText="Select a case..."
                SelectionChanged="CaseComboBox_SelectionChanged" />
          </DataTemplate>
        </uer:FeedView.ValueTemplate>
        <uer:FeedView.ProgressTemplate>
          <DataTemplate>
            <ProgressRing IsActive="True" Width="24" Height="24" />
          </DataTemplate>
        </uer:FeedView.ProgressTemplate>
      </uer:FeedView>
    </Grid>

    <!-- Row 1: Command buttons -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
      <Button Content="blockMesh"
          Command="{Binding RunBlockMesh}" />
      <Button Content="checkMesh"
          Command="{Binding RunCheckMesh}" />
      <Button Content="snappyHexMesh"
          Command="{Binding RunSnappyHexMesh}" />
      <Button Content="decomposePar"
          Command="{Binding RunDecomposePar}" />

      <!-- Solver button: label updates dynamically -->
      <uer:FeedView Source="{Binding SolverName}">
        <uer:FeedView.ValueTemplate>
          <DataTemplate>
            <Button Content="{Binding}"
                Command="{Binding DataContext.RunSolver, ElementName=RunControlRoot}" />
          </DataTemplate>
        </uer:FeedView.ValueTemplate>
        <uer:FeedView.ProgressTemplate>
          <DataTemplate>
            <Button Content="(solver)" IsEnabled="False" />
          </DataTemplate>
        </uer:FeedView.ProgressTemplate>
      </uer:FeedView>

      <Button Content="reconstructPar"
          Command="{Binding RunReconstructPar}" />
    </StackPanel>

    <!-- Row 2: Custom command -->
    <Grid Grid.Row="2" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBox PlaceholderText="Custom command (e.g. potentialFoam)"
          Text="{Binding CustomCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          FontFamily="Cascadia Code, Consolas, Courier New, monospace" />

      <Button Grid.Column="1"
          Content="Run"
          Command="{Binding RunCustom}" />
    </Grid>

    <!-- Row 3: Jobs list -->
    <uer:FeedView Source="{Binding Jobs}" Grid.Row="3">

      <uer:FeedView.ValueTemplate>
        <DataTemplate>
          <ListView ItemsSource="{Binding}"
              SelectionMode="None">
            <ListView.HeaderTemplate>
              <DataTemplate>
                <Grid Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="4,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="80" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Case" FontWeight="SemiBold"
                      Style="{ThemeResource CaptionTextBlockStyle}" />
                  <TextBlock Text="Command" Grid.Column="1" FontWeight="SemiBold"
                      Style="{ThemeResource CaptionTextBlockStyle}" />
                  <TextBlock Text="Status" Grid.Column="2" FontWeight="SemiBold"
                      Style="{ThemeResource CaptionTextBlockStyle}" />
                  <TextBlock Text="Elapsed" Grid.Column="3" FontWeight="SemiBold"
                      Style="{ThemeResource CaptionTextBlockStyle}" />
                </Grid>
              </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid Padding="12,6"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="80" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="{Binding CaseName}"
                      VerticalAlignment="Center"
                      TextTrimming="CharacterEllipsis" />

                  <TextBlock Text="{Binding Command}" Grid.Column="1"
                      VerticalAlignment="Center"
                      FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                      FontSize="12"
                      TextTrimming="CharacterEllipsis" />

                  <!-- Status badge -->
                  <Border Grid.Column="2"
                      Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                      CornerRadius="4"
                      Padding="8,2"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}"
                        FontSize="12"
                        Foreground="White" />
                  </Border>

                  <TextBlock Text="{Binding Elapsed}" Grid.Column="3"
                      VerticalAlignment="Center"
                      Style="{ThemeResource CaptionTextBlockStyle}" />

                  <!-- Cancel button (only for running/queued) -->
                  <Button Grid.Column="4"
                      Content="Cancel"
                      Padding="8,4"
                      Command="{Binding DataContext.CancelJob, ElementName=RunControlRoot}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding CanCancel}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </DataTemplate>
      </uer:FeedView.ValueTemplate>

      <uer:FeedView.ProgressTemplate>
        <DataTemplate>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressRing IsActive="True" />
            <TextBlock Text="Loading jobs..."
                Style="{ThemeResource BodyMediumTextBlockStyle}"
                Opacity="0.6" />
          </StackPanel>
        </DataTemplate>
      </uer:FeedView.ProgressTemplate>

      <uer:FeedView.NoneTemplate>
        <DataTemplate>
          <TextBlock Text="No jobs yet. Select a case and run a command."
              Style="{ThemeResource BodyMediumTextBlockStyle}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Opacity="0.6" />
        </DataTemplate>
      </uer:FeedView.NoneTemplate>

      <uer:FeedView.ErrorTemplate>
        <DataTemplate>
          <TextBlock Text="Failed to load jobs. Is the backend running?"
              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center" />
        </DataTemplate>
      </uer:FeedView.ErrorTemplate>

    </uer:FeedView>
  </Grid>
</Page>
