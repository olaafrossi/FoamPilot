<Page x:Class="FoamPilot.Ui.Presentation.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource BackgroundBrush}">

  <ScrollViewer>
    <Grid Padding="24" RowSpacing="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock Text="Settings"
          Style="{ThemeResource TitleLargeTextBlockStyle}" />

      <StackPanel Grid.Row="1" Spacing="24" MaxWidth="480" HorizontalAlignment="Left">

        <!-- Backend -->
        <StackPanel Spacing="12">
          <TextBlock Text="Backend"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBox x:Name="BackendUrlBox"
              Header="Backend URL"
              PlaceholderText="http://localhost:8000" />

          <TextBox x:Name="DockerComposePathBox"
              Header="Docker Compose Path"
              PlaceholderText="./docker" />

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BtnStartContainer" Content="Start Container" Click="StartContainer_Click" />
            <Button x:Name="BtnStopContainer" Content="Stop Container" Click="StopContainer_Click" />
            <TextBlock x:Name="DockerStatusText" VerticalAlignment="Center"
                Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
          </StackPanel>

          <ToggleSwitch x:Name="AutoStartToggle"
              Header="Auto-start container on launch"
              Toggled="AutoStart_Toggled" />
        </StackPanel>

        <!-- Paths -->
        <StackPanel Spacing="12">
          <TextBlock Text="Paths"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBox x:Name="ParaViewPathBox"
              Header="ParaView Executable Path"
              PlaceholderText="C:\Program Files\ParaView 6.0.1\bin\paraview.exe" />

          <TextBox x:Name="LocalCasesPathBox"
              Header="Local Cases Folder"
              PlaceholderText="C:\Dev\FoamPilot\cases" />
        </StackPanel>

        <!-- Appearance -->
        <StackPanel Spacing="12">
          <TextBlock Text="Appearance"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <ComboBox x:Name="ThemeComboBox"
              Header="Theme"
              SelectionChanged="ThemeComboBox_SelectionChanged">
            <x:String>System</x:String>
            <x:String>Light</x:String>
            <x:String>Dark</x:String>
          </ComboBox>
        </StackPanel>

        <!-- Save -->
        <Button Content="Save Settings" Click="Save_Click"
            Style="{ThemeResource AccentButtonStyle}"
            Padding="16,8" />

        <TextBlock x:Name="SaveStatus" Opacity="0.7"
            Style="{ThemeResource CaptionTextBlockStyle}" />

      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
