<Page x:Class="FoamPilot.Ui.Presentation.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uer="using:Uno.Extensions.Reactive.UI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource BackgroundBrush}">

  <ScrollViewer>
    <Grid Padding="24" RowSpacing="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock Text="Settings"
          Style="{ThemeResource TitleLargeTextBlockStyle}" />

      <StackPanel Grid.Row="1" Spacing="24" MaxWidth="480" HorizontalAlignment="Left">

        <!-- Backend -->
        <StackPanel Spacing="12">
          <TextBlock Text="Backend"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBox Header="Backend URL"
              Text="{Binding BackendUrl, Mode=TwoWay}"
              PlaceholderText="http://localhost:8000" />

          <TextBox Header="Docker Compose Path"
              Text="{Binding DockerComposePath, Mode=TwoWay}"
              PlaceholderText="./docker" />

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start Container"
                Command="{Binding StartContainer}" />
            <Button Content="Stop Container"
                Command="{Binding StopContainer}" />
          </StackPanel>

          <ToggleSwitch Header="Auto-start container on launch"
              IsOn="{Binding AutoStartContainer, Mode=TwoWay}"
              Toggled="AutoStart_Toggled" />
        </StackPanel>

        <!-- ParaView -->
        <StackPanel Spacing="12">
          <TextBlock Text="ParaView"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <TextBox Header="ParaView Executable Path"
              Text="{Binding ParaViewPath, Mode=TwoWay}"
              PlaceholderText="Path to paraview executable"
              LostFocus="ParaViewPath_LostFocus" />
        </StackPanel>

        <!-- Appearance -->
        <StackPanel Spacing="12">
          <TextBlock Text="Appearance"
              Style="{ThemeResource SubtitleTextBlockStyle}" />

          <ComboBox x:Name="ThemeComboBox"
              Header="Theme"
              SelectedItem="{Binding Theme, Mode=TwoWay}"
              SelectionChanged="ThemeComboBox_SelectionChanged">
            <x:String>System</x:String>
            <x:String>Light</x:String>
            <x:String>Dark</x:String>
          </ComboBox>
        </StackPanel>

      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
