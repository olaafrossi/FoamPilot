<Page x:Class="FoamPilot.Ui.Presentation.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="24" RowSpacing="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Dashboard"
        Style="{ThemeResource TitleLargeTextBlockStyle}" />

    <!-- Summary cards -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">

      <!-- Total Cases -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Total Cases"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <TextBlock x:Name="CaseCountText" Text="--"
              Style="{ThemeResource TitleLargeTextBlockStyle}" />
        </StackPanel>
      </Border>

      <!-- Active Jobs -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Active Jobs"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <TextBlock x:Name="ActiveJobsText" Text="--"
              Style="{ThemeResource TitleLargeTextBlockStyle}" />
        </StackPanel>
      </Border>

      <!-- Container Status -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Container"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse x:Name="ContainerDot" Width="14" Height="14"
                Fill="Gray" VerticalAlignment="Center" />
            <TextBlock x:Name="ContainerStatusText" Text="--"
                Style="{ThemeResource TitleLargeTextBlockStyle}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Backend -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Backend"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse x:Name="BackendDot" Width="14" Height="14"
                Fill="Gray" VerticalAlignment="Center" />
            <TextBlock x:Name="BackendStatusText" Text="--"
                Style="{ThemeResource TitleLargeTextBlockStyle}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Recent Jobs -->
    <Grid Grid.Row="2" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock Text="Recent Jobs"
          Style="{ThemeResource SubtitleTextBlockStyle}" />

      <ListView x:Name="JobsList" Grid.Row="1" SelectionMode="None">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="12,6"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1.5*" />
              </Grid.ColumnDefinitions>

              <TextBlock Text="{Binding CaseName}"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis" />

              <TextBlock Text="{Binding Command}" Grid.Column="1"
                  VerticalAlignment="Center"
                  FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                  FontSize="12"
                  TextTrimming="CharacterEllipsis" />

              <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                  HorizontalAlignment="Left" VerticalAlignment="Center"
                  Background="{ThemeResource SystemFillColorNeutralBrush}">
                <TextBlock Text="{Binding Status}" FontSize="12" />
              </Border>

              <TextBlock Text="{Binding Elapsed}" Grid.Column="3"
                  VerticalAlignment="Center"
                  Style="{ThemeResource CaptionTextBlockStyle}" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <TextBlock x:Name="NoJobsText" Grid.Row="1"
          Text="No jobs yet. Run a simulation from Quick Run or Run Control."
          HorizontalAlignment="Center" VerticalAlignment="Center"
          Opacity="0.5" Visibility="Collapsed" />
    </Grid>
  </Grid>
</Page>
