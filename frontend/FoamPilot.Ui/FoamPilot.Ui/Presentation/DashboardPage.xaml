<Page x:Class="FoamPilot.Ui.Presentation.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uer="using:Uno.Extensions.Reactive.UI"
    xmlns:local="using:FoamPilot.Ui.Presentation"
    Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <local:ContainerStatusToColorConverter x:Key="StatusColor" />
    <local:JobStatusToBrushConverter x:Key="StatusBrush" />
  </Page.Resources>

  <Grid Padding="24" RowSpacing="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock Text="Dashboard"
        Style="{ThemeResource TitleLargeTextBlockStyle}" />

    <!-- Summary cards row -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">

      <!-- Total Cases card -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Total Cases"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <uer:FeedView Source="{Binding CaseCount}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                    Style="{ThemeResource TitleLargeTextBlockStyle}" />
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
              <DataTemplate>
                <ProgressRing IsActive="True" Width="20" Height="20" />
              </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.ErrorTemplate>
              <DataTemplate>
                <TextBlock Text="--" Style="{ThemeResource TitleLargeTextBlockStyle}" Opacity="0.4" />
              </DataTemplate>
            </uer:FeedView.ErrorTemplate>
          </uer:FeedView>
        </StackPanel>
      </Border>

      <!-- Active Jobs card -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Active Jobs"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <uer:FeedView Source="{Binding ActiveJobCount}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                    Style="{ThemeResource TitleLargeTextBlockStyle}" />
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
              <DataTemplate>
                <ProgressRing IsActive="True" Width="20" Height="20" />
              </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.ErrorTemplate>
              <DataTemplate>
                <TextBlock Text="--" Style="{ThemeResource TitleLargeTextBlockStyle}" Opacity="0.4" />
              </DataTemplate>
            </uer:FeedView.ErrorTemplate>
          </uer:FeedView>
        </StackPanel>
      </Border>

      <!-- Container Status card -->
      <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1" CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          Padding="20" MinWidth="180">
        <StackPanel Spacing="8">
          <TextBlock Text="Container"
              Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" />
          <uer:FeedView Source="{Binding ContainerState}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Ellipse Width="14" Height="14"
                      Fill="{Binding Converter={StaticResource StatusColor}}"
                      VerticalAlignment="Center" />
                  <TextBlock Text="{Binding}"
                      Style="{ThemeResource TitleLargeTextBlockStyle}" />
                </StackPanel>
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
              <DataTemplate>
                <ProgressRing IsActive="True" Width="20" Height="20" />
              </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.ErrorTemplate>
              <DataTemplate>
                <TextBlock Text="--" Style="{ThemeResource TitleLargeTextBlockStyle}" Opacity="0.4" />
              </DataTemplate>
            </uer:FeedView.ErrorTemplate>
          </uer:FeedView>
        </StackPanel>
      </Border>

    </StackPanel>

    <!-- Recent Jobs list -->
    <Grid Grid.Row="2" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock Text="Recent Jobs"
          Style="{ThemeResource SubtitleTextBlockStyle}" />

      <uer:FeedView Source="{Binding RecentJobs}" Grid.Row="1">
        <uer:FeedView.ValueTemplate>
          <DataTemplate>
            <ListView ItemsSource="{Binding}" SelectionMode="None">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Padding="12,6"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="2*" />
                      <ColumnDefinition Width="3*" />
                      <ColumnDefinition Width="1.5*" />
                      <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding CaseName}"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis" />

                    <TextBlock Text="{Binding Command}" Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                        FontSize="12"
                        TextTrimming="CharacterEllipsis" />

                    <Border Grid.Column="2"
                        Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                        CornerRadius="4"
                        Padding="8,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status}"
                          FontSize="12"
                          Foreground="White" />
                    </Border>

                    <TextBlock Text="{Binding Elapsed}" Grid.Column="3"
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </DataTemplate>
        </uer:FeedView.ValueTemplate>

        <uer:FeedView.ProgressTemplate>
          <DataTemplate>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
              <ProgressRing IsActive="True" />
              <TextBlock Text="Loading jobs..."
                  Style="{ThemeResource BodyMediumTextBlockStyle}" Opacity="0.6" />
            </StackPanel>
          </DataTemplate>
        </uer:FeedView.ProgressTemplate>

        <uer:FeedView.NoneTemplate>
          <DataTemplate>
            <TextBlock Text="No jobs yet. Run a simulation from Run Control."
                Style="{ThemeResource BodyMediumTextBlockStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.6" />
          </DataTemplate>
        </uer:FeedView.NoneTemplate>

        <uer:FeedView.ErrorTemplate>
          <DataTemplate>
            <TextBlock Text="Failed to load jobs. Is the backend running?"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
          </DataTemplate>
        </uer:FeedView.ErrorTemplate>

      </uer:FeedView>
    </Grid>
  </Grid>
</Page>
