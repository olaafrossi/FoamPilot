<Page x:Class="FoamPilot.Ui.Presentation.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="24" RowSpacing="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Logs"
        Style="{ThemeResource TitleLargeTextBlockStyle}" />

    <!-- Job selector -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
      <ComboBox x:Name="JobCombo" Header="Select Job" Width="400"
          SelectionChanged="JobCombo_SelectionChanged" />
      <Button Content="Refresh Jobs" Click="RefreshJobs_Click"
          VerticalAlignment="Bottom" Padding="12,8" />
      <ToggleSwitch x:Name="AutoScrollToggle" Header="Auto-scroll"
          IsOn="True" VerticalAlignment="Bottom" />
      <TextBlock x:Name="StatusText" VerticalAlignment="Bottom"
          Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"
          Margin="8,0,0,6" />
    </StackPanel>

    <!-- Log output -->
    <Border Grid.Row="2"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1" CornerRadius="8" Padding="8">
      <ScrollViewer x:Name="LogScroll">
        <TextBlock x:Name="LogOutput"
            FontFamily="Cascadia Code, Consolas, Courier New, monospace"
            FontSize="12"
            TextWrapping="NoWrap"
            IsTextSelectionEnabled="True" />
      </ScrollViewer>
    </Border>
  </Grid>
</Page>
