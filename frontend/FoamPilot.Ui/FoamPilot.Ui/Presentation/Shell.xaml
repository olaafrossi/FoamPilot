<UserControl x:Class="FoamPilot.Ui.Presentation.Shell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FoamPilot.Ui.Presentation"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:uer="using:Uno.Extensions.Reactive.UI">

  <Grid Background="{ThemeResource BackgroundBrush}">
    <muxc:NavigationView x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsPaneToggleButtonVisible="True"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        uen:Navigation.Request="/"
        OpenPaneLength="220">

      <muxc:NavigationView.MenuItems>
        <muxc:NavigationViewItem Content="Dashboard"
            uen:Navigation.Request="Dashboard"
            Icon="Home" />
        <muxc:NavigationViewItem Content="Cases"
            uen:Navigation.Request="Cases"
            Icon="AllApps" />
        <muxc:NavigationViewItem Content="Run Control"
            uen:Navigation.Request="RunControl"
            Icon="Play" />
        <muxc:NavigationViewItem Content="Logs"
            uen:Navigation.Request="Logs"
            Icon="List" />
        <muxc:NavigationViewItem Content="Dict Editor"
            uen:Navigation.Request="DictEditor"
            Icon="Edit" />
      </muxc:NavigationView.MenuItems>

      <muxc:NavigationView.FooterMenuItems>
        <muxc:NavigationViewItem Content="Settings"
            uen:Navigation.Request="Settings"
            Icon="Setting" />
      </muxc:NavigationView.FooterMenuItems>

      <muxc:NavigationView.PaneFooter>
        <StackPanel Padding="16,8" Spacing="4">
          <uer:FeedView Source="{Binding ContainerState}">
            <uer:FeedView.ValueTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10"
                      Fill="{Binding Converter={StaticResource StatusColorConverter}}" />
                  <TextBlock Text="{Binding}"
                      Style="{ThemeResource CaptionTextBlockStyle}"
                      Opacity="0.7" />
                </StackPanel>
              </DataTemplate>
            </uer:FeedView.ValueTemplate>
          </uer:FeedView>
        </StackPanel>
      </muxc:NavigationView.PaneFooter>

      <!-- Content area where pages render -->
      <Grid>
        <utu:ExtendedSplashScreen x:Name="Splash"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch">
          <utu:ExtendedSplashScreen.LoadingContentTemplate>
            <DataTemplate>
              <Grid>
                <ProgressRing IsActive="True"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Height="80"
                    Width="80" />
              </Grid>
            </DataTemplate>
          </utu:ExtendedSplashScreen.LoadingContentTemplate>
        </utu:ExtendedSplashScreen>
      </Grid>
    </muxc:NavigationView>
  </Grid>
</UserControl>
