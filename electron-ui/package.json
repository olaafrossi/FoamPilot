{
  "name": "foampilot",
  "version": "0.0.1",
  "description": "Aerodynamics made simple — guided OpenFOAM simulations",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:preload && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.ts\"",
    "build:preload": "tsc -p tsconfig.preload.json",
    "clean:electron": "node -e \"require('fs').rmSync('electron-dist',{recursive:true,force:true})\"",
    "verify:preload": "node -e \"const f=require('fs').readFileSync('electron-dist/preload.js','utf8'); if(!f.includes('require(\\\"electron\\\")')) { console.error('FAIL: preload.js is not CommonJS'); process.exit(1); } console.log('OK: preload.js is CommonJS');\"",
    "build": "tsc && vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:electron": "npm run build && npm run clean:electron && npm run build:main && npm run build:preload && npm run verify:preload && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cfd",
    "openfoam",
    "aerodynamics",
    "simulation"
  ],
  "author": "OlaafRossi",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.foampilot.app",
    "productName": "FoamPilot",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "olaafrossi",
        "repo": "FoamPilot"
      }
    ],
    "icon": "build/icon.png",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../docker/docker-compose.prod.yml",
        "to": "docker-compose.yml"
      }
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2"
  }
}
