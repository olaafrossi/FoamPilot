{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "electron-dist",
    "rootDir": "electron"
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["electron/__tests__"]
}
