forceCoeffs1
{
    type            forceCoeffs;

    libs            (forces);

    writeControl    timeStep;
    writeInterval   1;

    log             yes;

    patches         (smallPlaneGroup);
    rho             rhoInf;      // Indicates incompressible
    rhoInf          1;           // Required when rho = rhoInf
    liftDir         (0 0 1);
    dragDir         (1 0 0);
    CofR            (0.5 0 0);   // Quarter-chord position
    pitchAxis       (0 1 0);
    magUInf         30;
    lRef            2.0;         // Wingspan or chord
    Aref            1.5;         // Wing planform area
}


